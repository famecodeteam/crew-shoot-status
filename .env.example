# Trello — reused from the HAM Dashboard / Meeting Agenda Compiler creds.
# Source from your password manager or the HAM Dashboard repo's local .env.
TRELLO_KEY=
TRELLO_TOKEN=

# Crew Delivery board. The shortLink (https://trello.com/b/fMONysxJ → fMONysxJ)
# works as a board ID — Trello's API accepts both forms.
TRELLO_BOARD_ID=fMONysxJ

# Webhook signing secret. Used to verify Trello-originated POSTs to
# /api/trello-webhook. Optional in dev (handler short-circuits validation
# when unset and warns on every request) — required in production.
TRELLO_WEBHOOK_SECRET=

# Public URL Trello will hit. Used by the webhook signature check (it
# includes this exact string in the HMAC), and by the webhook-register
# script. e.g. https://shoots.fame.so/api/trello-webhook
TRELLO_WEBHOOK_CALLBACK_URL=

# Public base URL for the status pages. Used to (a) compose the URL
# written back to each card's "Status Page URL" custom field, and (b)
# anywhere else we need to render a full link.
# Production: https://shoots.fame.so
# Local dev:  http://localhost:3000  (or leave blank to skip write-back)
PUBLIC_BASE_URL=

# Google service account — reuses the HAM Dashboard / Meeting Agenda key.
# Local dev: point at the JSON file on disk.
# CI / production: paste the whole JSON as one line into GOOGLE_SERVICE_ACCOUNT_JSON instead.
# Used to (a) look up each shoot's #NNNN folder in Drive and pull the brief
# (Google Doc with "brief" in the name) and signed quote (PDF with "quote"),
# and (b) read brief Doc structure for the doc-synced /brief/[slug] page.
# The latter adds `documents.readonly` to the scope list at call time;
# the SA already has access to brief Docs via the shared folders.
GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Vercel Cron secret. When set, the /api/sync-briefs route requires
# Authorization: Bearer <CRON_SECRET> on every request — Vercel injects
# this header on cron-triggered calls automatically. Leave blank locally;
# the route is callable without auth when unset, so `curl /api/sync-briefs`
# works during dev.
CRON_SECRET=

# Cloudflare Stream — the video delivery layer. Finished review videos are
# ingested into Stream (transcoded, adaptive HLS, CDN-cached) so playback is
# fast regardless of the editor's export size. The Drive file stays the
# master; Stream is a derived delivery copy. See lib/stream.ts.
CF_ACCOUNT_ID=
# API token with Account · Stream · Edit
CF_STREAM_TOKEN=
# The "customer-<code>" playback subdomain (customer-<code>.cloudflarestream.com)
CF_STREAM_CUSTOMER_CODE=
